<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>My Addresses - ChronoLux</title>
</head>
<body style="background:#0d0d0d; min-height:100vh;">

<%- include('../partials/navbar', { user: user }) %>

<div class="container py-4">
  <div class="row g-4">
    <div class="col-12 col-lg-3">
      <%- include('../partials/profileSidebar', { user: user, active: 'address' }) %>
    </div>

    <div class="col-12 col-lg-9">
      <div class="profile-panel text-white">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h3 class="fw-bold mb-0">Address</h3>
          <a href="/address/add" class="btn btn-warning fw-bold">+ Add Address</a>
        </div>

        <input type="text" class="form-control mb-3" id="addressSearch" placeholder="Search here">

        <div class="table-responsive">
          <table class="table table-dark align-middle" id="addressTable">
            <thead>
              <tr>
                <th>Name</th>
                <th>Phone</th>
                <th>Address</th>
                <th>Type</th>
                <th>Default</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="addressTableBody">
              <% addresses.forEach(addr => { %>
              <tr data-id="<%= addr._id %>">
                <td><%= addr.fullName %></td>
                <td><%= addr.phone %></td>
                <td><%= addr.fullAddress %>, <%= addr.city %>, <%= addr.state %>-<%= addr.pincode %></td>
                <td><span class="badge bg-secondary"><%= addr.label %></span></td>
                <td>
                  <% if (addr.isDefault) { %>
                    <span class="badge bg-success">Default</span>
                  <% } else { %>
                    <span class="text-secondary">—</span>
                  <% } %>
                </td>
                <td>
                 <div class="d-flex gap-2">
                  <a href="/address/edit/<%= addr._id %>" class="btn btn-sm btn-secondary"><i class="bi bi-pencil"></i></a>
                  <button class="btn btn-sm btn-danger delete-address-btn" data-id="<%= addr._id %>"><i class="bi bi-trash"></i></button>
               </div>
               </td>
              </tr>
              <% }) %>
            </tbody>
          </table>

          <% if (addresses.length === 0) { %>
            <p class="text-center text-secondary py-4">No addresses added yet.</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
<%- include('../partials/scripts') %>
<script src="/js/address.js"></script>
</body>
</html>