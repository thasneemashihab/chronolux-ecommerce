<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Sign Up - ChronoLux</title>
  <link href="/css/auth.css" rel="stylesheet">
</head>
<body style="background:#0d0d0d;">

<div class="container-fluid d-flex align-items-center justify-content-center" style="min-height:100vh;">
  <div class="row auth-card-row shadow-lg rounded overflow-hidden" style="max-width:950px;">

    <!-- LEFT: Brand panel -->

    <div class="col-12 col-lg-5 auth-brand-panel text-center p-4 d-flex flex-column justify-content-center">
  <img src="/images/logo.png" class="logo mb-2" alt="ChronoLux logo">
  <h1 class="fw-bold">CHRONOLUX</h1>
  <div class="text-warning small mb-3">— TIMELESS ELEGANCE —</div>
  <img src="/images/luxury.jpg" class="img-fluid rounded" alt="Luxury watch">
</div>

    <!-- RIGHT: Signup form -->
    <div class="col-12 col-lg-7 auth-form-panel p-4 p-lg-5">
      <h2 class="fw-bold text-white">Create Account <span class="icon-badge">👤</span></h2>
      <p class="text-secondary mb-4">Join ChronoLux today</p>

      <form id="signupForm" novalidate>

        <div class="mb-3">
          <label class="form-label text-white">Name</label>
          <input type="text" class="form-control" id="name" placeholder="Enter your name">
          <div class="text-danger small mt-1" id="nameError"></div>
        </div>

        <div class="mb-3">
          <label class="form-label text-white">Email</label>
          <input type="email" class="form-control" id="email" placeholder="Enter your email">
          <div class="text-danger small mt-1" id="emailError"></div>
        </div>

        <div class="mb-3">
          <label class="form-label text-white">Password</label>
          <div class="position-relative">
            <input type="password" class="form-control" id="password" placeholder="Enter your password">
            <span class="toggle-eye position-absolute top-50 end-0 translate-middle-y me-3" data-target="password">
              <i class="bi bi-eye-slash-fill"></i>
            </span>
          </div>
          <div class="text-danger small mt-1" id="passwordError"></div>
        </div>

        <div class="mb-3">
          <label class="form-label text-white">Confirm Password</label>
          <div class="position-relative">
            <input type="password" class="form-control" id="confirmPassword" placeholder="Re-enter your password">
            <span class="toggle-eye position-absolute top-50 end-0 translate-middle-y me-3" data-target="confirmPassword">
              <i class="bi bi-eye-slash-fill"></i>
            </span>
          </div>
          <div class="text-danger small mt-1" id="confirmPasswordError"></div>
        </div>

        <div class="mb-2">
  <label class="form-label text-white">Referral code (optional)</label>
  <input type="text" class="form-control" id="referralCode" placeholder="Enter referral code (optional)">
</div>
<p class="small mb-2" style="font-size:12px; color:#aaa; text-decoration:none;">Have a referral code? Enter it here</p>

<div class="alert alert-danger d-none" id="formAlert"></div>

<button type="submit" class="btn btn-warning fw-bold w-100 mb-2">SignUp</button>

<p class="text-center text-white small mb-2">OR</p>

<button type="button" class="btn btn-secondary w-100 mb-2" id="googleSignup">
  <img src="/images/google.png" width="18" alt="Google" class="me-2">Sign Up with Google
</button>
        <p class="text-center text-secondary">Already have an account? <a href="/login" class="text-warning fw-bold text-decoration-none">Log In</a></p>
      </form>
    </div>

  </div>
</div>

<%- include('../partials/scripts') %>
<script src="/js/main.js"></script>
<script src="/js/signup.js"></script>
</body>
</html>