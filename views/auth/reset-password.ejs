<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Reset Password - ChronoLux</title>
  <link href="/css/auth.css" rel="stylesheet">
</head>
<body style="background:#0d0d0d;">

<div class="auth-wrapper">
  <div class="row auth-card-row shadow-lg rounded overflow-hidden">

    <div class="col-12 col-lg-5 auth-brand-panel text-center p-4">
      <img src="/images/logo.png" class="logo mb-2" alt="ChronoLux logo">
      <h1 class="fw-bold">CHRONOLUX</h1>
      <div class="text-warning small mb-3">— TIMELESS ELEGANCE —</div>
      <img src="/images/watch-hero.jpg" class="img-fluid rounded" alt="Luxury watch">
    </div>

    <div class="col-12 col-lg-7 auth-form-panel p-4 p-lg-5 text-center">
      <div class="otp-icon mx-auto"><i class="bi bi-shield-lock-fill"></i></div>
      <h2 class="fw-bold text-white mt-2">Reset Password</h2>
      <p class="text-secondary">Set a new password for your account.</p>

      <form id="resetForm" class="text-start mt-4">
        <label class="form-label text-white">New Password</label>
        <div class="position-relative">
          <input type="password" class="form-control" id="newPassword" placeholder="Enter new password">
          <span class="toggle-eye position-absolute top-50 end-0 translate-middle-y me-3" data-target="newPassword">
            <i class="bi bi-eye-fill"></i>
          </span>
        </div>

        <label class="form-label text-white mt-3">Confirm New Password</label>
        <div class="position-relative">
          <input type="password" class="form-control" id="confirmPassword" placeholder="Re-enter new password">
          <span class="toggle-eye position-absolute top-50 end-0 translate-middle-y me-3" data-target="confirmPassword">
            <i class="bi bi-eye-fill"></i>
          </span>
        </div>

        <div class="alert alert-danger d-none mt-3" id="formAlert"></div>

        <button type="submit" class="btn btn-warning fw-bold w-100 mt-3">Reset Password</button>

        <p class="text-center text-secondary small mt-3">Your password will be updated successfully.</p>
      </form>
    </div>

  </div>
</div>

<%- include('../partials/scripts') %>
<script src="/js/resetPassword.js"></script>
<script src="/js/main.js"></script>
</body>
</html>