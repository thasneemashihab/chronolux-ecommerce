<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Verify OTP - ChronoLux</title>
  <link href="/css/auth.css" rel="stylesheet">
</head>
<body style="background:#0d0d0d;">

<div class="auth-wrapper">
  <div class="row auth-card-row shadow-lg rounded overflow-hidden">

    <div class="col-12 col-lg-5 auth-brand-panel text-center p-4">
      <img src="/images/logo.png" class="logo mb-2" alt="ChronoLux logo">
      <h1 class="fw-bold">CHRONOLUX</h1>
      <div class="text-warning small mb-3">— TIMELESS ELEGANCE —</div>
      <img src="/images/watch.jpg" class="img-fluid rounded" alt="Luxury watch">
    </div>

    <div class="col-12 col-lg-7 auth-form-panel otp-form p-4 p-lg-5">
      <div class="otp-icon mx-auto"><i class="bi bi-envelope-fill"></i></div>
      <h2 class="otp-title">Verify OTP</h2>
      <p class="text-secondary">Enter the 6-digit code sent to</p>
      <p class="otp-email" id="emailDisplay"></p>

      <form id="resetOtpForm">
        <div class="otp-boxes">
          <input type="text" maxlength="1" class="otp-box" data-index="0" inputmode="numeric">
          <input type="text" maxlength="1" class="otp-box" data-index="1" inputmode="numeric">
          <input type="text" maxlength="1" class="otp-box" data-index="2" inputmode="numeric">
          <input type="text" maxlength="1" class="otp-box" data-index="3" inputmode="numeric">
          <input type="text" maxlength="1" class="otp-box" data-index="4" inputmode="numeric">
          <input type="text" maxlength="1" class="otp-box" data-index="5" inputmode="numeric">
        </div>
        <div class="field-error text-center" id="otpError"></div>

        <p class="otp-timer text-center">Resend OTP in <span id="timer">01:00</span></p>

        <button type="submit" class="btn btn-warning fw-bold w-100">Verify OTP</button>

        <p class="text-center text-secondary small mt-3">
          Didn't receive code? <a href="#" id="resendBtn" class="resend-disabled">Resend OTP</a>
        </p>
      </form>
    </div>

  </div>
</div>

<%- include('../partials/scripts') %>
<script src="/js/verifyResetOtp.js"></script>
</body>
</html>