<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Forgot Password - ChronoLux</title>
  <link href="/css/auth.css" rel="stylesheet">
</head>
<body style="background:#0d0d0d;">

<div class="auth-wrapper">
  <div class="row auth-card-row shadow-lg rounded overflow-hidden">

    <!-- LEFT: Brand panel -->
    <div class="col-12 col-lg-5 auth-brand-panel text-center p-4">
      <img src="/images/logo.png" class="logo mb-2" alt="ChronoLux logo">
      <h1 class="fw-bold">CHRONOLUX</h1>
      <div class="text-warning small mb-3">— TIMELESS ELEGANCE —</div>
      <img src="/images/watch.jpg" class="img-fluid rounded" alt="Luxury watch">
    </div>

    <!-- RIGHT: Forgot password form -->
    <div class="col-12 col-lg-7 auth-form-panel p-4 p-lg-5 text-center">
      <div class="otp-icon mx-auto"><i class="bi bi-shield-lock-fill"></i></div>
      <h2 class="fw-bold text-white mt-2">Forgot Password</h2>
      <p class="text-secondary">Enter your registered email address<br>and we will send you a verification code.</p>

      <form id="forgotForm" class="text-start mt-4">
        <label class="form-label text-white">Email Address</label>
        <input type="email" class="form-control" id="email" placeholder="Enter your email">
        <div class="text-danger small mt-1" id="emailError"></div>

        <div class="alert alert-danger d-none mt-3" id="formAlert"></div>

        <button type="submit" class="btn btn-warning fw-bold w-100 mt-3">Send OTP</button>

        <p class="text-center text-secondary small mt-2">We will send a 6-digit OTP to your email</p>
      </form>
    </div>

  </div>
</div>

<%- include('../partials/scripts') %>
<script src="/js/forgotPassword.js"></script>
</body>
</html>